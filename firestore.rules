rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: tasks
    // Fields: title (string), description (string), status (string), priority (string), dueDate (string), userId (string)
    //
    // Collection: events
    // Fields: title (string), startTime (string), endTime (string), location (string), description (string), userId (string)
    //
    // Collection: notes
    // Fields: title (string), content (string), tags (list), createdAt (string), userId (string)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "mathury2006@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidTask(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.status in ['pending', 'in-progress', 'completed'] &&
             (data.priority == null || data.priority in ['low', 'medium', 'high']) &&
             data.userId == request.auth.uid;
    }

    function isValidEvent(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.startTime is string && data.endTime is string &&
             data.userId == request.auth.uid;
    }

    function isValidNote(data) {
      return data.content is string && data.content.size() > 0 && data.content.size() < 10000 &&
             data.userId == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && (request.resource.data.role == 'user' || isAdmin());
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidTask(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidTask(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /events/{eventId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidEvent(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidEvent(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /notes/{noteId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidNote(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidNote(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}

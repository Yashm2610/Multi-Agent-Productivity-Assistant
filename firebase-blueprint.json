{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A task to be completed",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the task" },
        "description": { "type": "string", "description": "Detailed description" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed"], "description": "Current status" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"], "description": "Priority level" },
        "dueDate": { "type": "string", "format": "date-time", "description": "When the task is due" },
        "userId": { "type": "string", "description": "Owner of the task" }
      },
      "required": ["title", "status", "userId"]
    },
    "Event": {
      "title": "Event",
      "description": "A calendar event",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Event title" },
        "startTime": { "type": "string", "format": "date-time", "description": "Start time" },
        "endTime": { "type": "string", "format": "date-time", "description": "End time" },
        "location": { "type": "string", "description": "Where it happens" },
        "description": { "type": "string", "description": "Event details" },
        "userId": { "type": "string", "description": "Owner of the event" }
      },
      "required": ["title", "startTime", "endTime", "userId"]
    },
    "Note": {
      "title": "Note",
      "description": "A simple note or piece of information",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Note title" },
        "content": { "type": "string", "description": "Note content" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Categorization tags" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "userId": { "type": "string", "description": "Owner of the note" }
      },
      "required": ["content", "userId"]
    }
  },
  "firestore": {
    "tasks": { "schema": "Task", "description": "User tasks" },
    "events": { "schema": "Event", "description": "Calendar events" },
    "notes": { "schema": "Note", "description": "Personal notes" }
  }
}
